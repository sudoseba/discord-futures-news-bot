# ─── Discord Bot (REQUIRED) ────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_GUILD_ID=your_server_id_here

# Channel for auto-posting briefings, recaps, breaking news, level breaks, etc.
AUTO_POST_CHANNEL_ID=channel_id_here

# Optional category-specific channels (falls back to AUTO_POST_CHANNEL_ID)
# CHANNEL_METALS=
# CHANNEL_OIL=
# CHANNEL_CRYPTO=
# CHANNEL_FOREX=

# ─── Market Data APIs (FREE) ───────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# ─── News APIs (OPTIONAL — bot falls back to RSS feeds if absent) ──────────
# NEWS_API_KEY=
# BENZINGA_API_KEY=

# ─── LLM (OPTIONAL — bot returns raw data if absent) ───────────────────────
# Cerebras: https://cloud.cerebras.ai — free tier covers daily use
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=gpt-oss-120b

# ─── Voice Recap (OPTIONAL — Deepgram free tier ≈ 60 min/mo) ───────────────
# DEEPGRAM_TTS_API_KEY=

# ─── Schedules (cron format, server timezone unless overridden) ────────────
SCHEDULE_TIMEZONE=America/New_York
BRIEFING_CRON=0 8 * * 1-5
RECAP_CRON=30 16 * * 1-5
ANOMALY_SCAN_CRON=*/15 * * * *
BREAKING_NEWS_CRON=*/5 * * * *
LEVEL_BREAK_CRON=*/5 * * * *
SCORECARD_RESOLVE_CRON=*/30 * * * *
COT_FRIDAY_CRON=30 16 * * 5
EVENT_OUTCOME_CRON=*/10 * * * *
DEADLETTER_DRAIN_CRON=*/1 * * * *

# ─── Caching & Performance ─────────────────────────────────────────────────
# How long AI outputs are cached before regenerating (ms). 0 = disable.
LLM_CACHE_TTL_MS=1200000

# ─── Logging ───────────────────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Set to true for pretty-printed logs in dev; false in prod for JSON
LOG_PRETTY=true

# ─── Health endpoint ───────────────────────────────────────────────────────
HEALTHZ_PORT=3000
HEALTHZ_ENABLED=true

# ─── Database ──────────────────────────────────────────────────────────────
# DB_VERBOSE=true   # logs every SQL statement (debug only)
