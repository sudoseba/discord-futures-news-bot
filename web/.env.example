# ─── Web Dashboard config ──────────────────────────────────────────────────
# This service reads shared Discord values (CLIENT_ID/SECRET/GUILD_ID) from the
# BOT's ../.env automatically, so you usually only need to fill in the few
# web-specific values below.

# Where the dashboard listens. 0.0.0.0 = reachable over your Tailnet/LAN.
WEB_PORT=8080
WEB_HOST=0.0.0.0

# The URL users actually reach the dashboard at (used to build the OAuth
# redirect and to set secure-cookie behavior). No trailing slash.
#   - Tailscale MagicDNS example:  http://raspberrypi:8080
#   - Tailscale IP example:        http://100.x.y.z:8080
#   - Tailscale HTTPS (serve):     https://raspberrypi.tailXXXX.ts.net
WEB_PUBLIC_URL=http://localhost:8080

# REQUIRED. Signs session cookies. Generate one with:  npm run secret
# If left blank the app generates an ephemeral one at boot (sessions won't
# survive a restart) and logs a warning.
SESSION_SECRET=

# ─── Discord OAuth2 ────────────────────────────────────────────────────────
# CLIENT_ID / CLIENT_SECRET / GUILD_ID are inherited from ../.env if present.
# You can override them here if the dashboard uses a different Discord app.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_GUILD_ID=

# The redirect URI. Leave blank to derive it as WEB_PUBLIC_URL + /auth/callback.
# Whatever this resolves to MUST be added verbatim under OAuth2 → Redirects
# in the Discord Developer Portal.
# OAUTH_REDIRECT_URI=

# ─── Access control ────────────────────────────────────────────────────────
# Only members of DISCORD_GUILD_ID may log in when true.
REQUIRE_GUILD_MEMBERSHIP=true

# Who gets the admin views (config, API tests, logs). Either works; a user is
# admin if their ID is listed OR they hold the admin role in the guild.
# Comma-separated Discord user IDs:
ADMIN_USER_IDS=
# A single Discord role ID that grants admin:
ADMIN_ROLE_ID=

# ─── Bot integration ───────────────────────────────────────────────────────
# The bot's health endpoint (defaults to the bot's HEALTHZ_PORT from ../.env).
# BOT_HEALTHZ_URL=http://127.0.0.1:3000/healthz
# Path to the bot's SQLite DB (defaults to ../data/bot.db).
# BOT_DB_PATH=

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
# true = pretty console logs (dev). Leave blank → pretty unless NODE_ENV=production.
# LOG_PRETTY=
# NODE_ENV=production
